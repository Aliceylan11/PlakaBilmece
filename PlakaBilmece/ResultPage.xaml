<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PlakaBilmece.ResultPage"
             BackgroundColor="#121212"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="Auto, *, Auto" Padding="15" RowSpacing="15">

        <VerticalStackLayout Grid.Row="0" HorizontalOptions="Center" Spacing="5">
            <Label x:Name="lblOyuncuMesaj" Text="TEBRİKLER!" FontSize="24" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center"/>

            <Label Text="SÜRE BİTTİ!" FontSize="16" TextColor="Gray" HorizontalOptions="Center"/>

            <Label x:Name="lblRekorMesaj" Text="YENİ REKOR! 🔥" FontSize="20" FontAttributes="Bold" TextColor="OrangeRed" IsVisible="False" HorizontalOptions="Center" Margin="0,5"/>

            <Label Text="TOPLAM PUAN" FontSize="14" TextColor="Gray" HorizontalOptions="Center" Margin="0,10,0,0"/>
            <Label x:Name="lblFinalPuan" Text="0" FontSize="48" FontAttributes="Bold" TextColor="Gold" HorizontalOptions="Center"/>

            <HorizontalStackLayout HorizontalOptions="Center" Spacing="20" Margin="0,10,0,0">
                <VerticalStackLayout HorizontalOptions="Center">
                    <Label Text="DOĞRU" FontSize="12" TextColor="LightGray" HorizontalOptions="Center"/>
                    <Label x:Name="lblDogruSayisi" Text="0" FontSize="32" FontAttributes="Bold" TextColor="LimeGreen" HorizontalOptions="Center"/>
                </VerticalStackLayout>
                <VerticalStackLayout HorizontalOptions="Center">
                    <Label Text="KAÇAN" FontSize="12" TextColor="LightGray" HorizontalOptions="Center"/>
                    <Label x:Name="lblKacanSayisi" Text="0" FontSize="32" FontAttributes="Bold" TextColor="Red" HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </HorizontalStackLayout>
        </VerticalStackLayout>

        <Grid Grid.Row="1" ColumnDefinitions="*, *" ColumnSpacing="15">
            <Grid Grid.Column="0" RowDefinitions="Auto, *">
                <Label Grid.Row="0" Text="BİLDİKLERİN" TextColor="LimeGreen" FontSize="12" FontAttributes="Bold" HorizontalOptions="Center" Margin="0,0,0,5"/>
                <Border Grid.Row="1" BackgroundColor="#1A1A1A" Stroke="#333" StrokeThickness="1" StrokeShape="RoundRectangle 10" Padding="5">
                    <CollectionView x:Name="cvBilinenler">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Label Text="{Binding .}" TextColor="White" FontSize="13" Margin="0,2"/>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Border>
            </Grid>

            <Grid Grid.Column="1" RowDefinitions="Auto, *">
                <Label Grid.Row="0" Text="KAÇIRDIKLARIN" TextColor="Red" FontSize="12" FontAttributes="Bold" HorizontalOptions="Center" Margin="0,0,0,5"/>
                <Border Grid.Row="1" BackgroundColor="#1A1A1A" Stroke="#333" StrokeThickness="1" StrokeShape="RoundRectangle 10" Padding="5">
                    <CollectionView x:Name="cvBilemediklerim">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Label Text="{Binding .}" TextColor="Gray" FontSize="13" Margin="0,2"/>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Border>
            </Grid>
        </Grid>

        <Grid Grid.Row="2" ColumnDefinitions="*, *" ColumnSpacing="10">
            <Button Grid.Column="0" Text="TEKRAR OYNA" Clicked="OnTekrarOynaClicked"
                    BackgroundColor="#1E88E5" TextColor="White" FontSize="14" FontAttributes="Bold" CornerRadius="10" HeightRequest="50"/>

            <Button Grid.Column="1" Text="ANA MENÜ" Clicked="OnAnaMenuClicked"
                    BackgroundColor="#333333" TextColor="White" FontSize="14" FontAttributes="Bold" CornerRadius="10" HeightRequest="50"/>
        </Grid>

    </Grid>
</ContentPage>