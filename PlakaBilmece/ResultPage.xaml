<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PlakaBilmece.ResultPage"
             BackgroundColor="#121212"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="Auto, *, Auto" Padding="15" RowSpacing="15">

        <VerticalStackLayout Grid.Row="0" HorizontalOptions="Center" Spacing="5">
            <Label Text="SÜRE BİTTİ!" FontSize="32" FontAttributes="Bold" TextColor="Gold" HorizontalOptions="Center"/>
            <Label Text="TOPLAM PUAN" FontSize="14" TextColor="Gray" HorizontalOptions="Center" Margin="0,10,0,0"/>
            <Label x:Name="lblFinalPuan" Text="0" FontSize="48" FontAttributes="Bold" TextColor="Gold" HorizontalOptions="Center"/>
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="20" Margin="0,10,0,0">
                <VerticalStackLayout HorizontalOptions="Center">
                    <Label Text="DOĞRU" FontSize="14" TextColor="LightGray" HorizontalOptions="Center"/>
                    <Label x:Name="lblDogruSayisi" Text="0" FontSize="36" FontAttributes="Bold" TextColor="LimeGreen" HorizontalOptions="Center"/>
                </VerticalStackLayout>
                <VerticalStackLayout HorizontalOptions="Center">
                    <Label Text="KAÇAN" FontSize="14" TextColor="LightGray" HorizontalOptions="Center"/>
                    <Label x:Name="lblKacanSayisi" Text="0" FontSize="36" FontAttributes="Bold" TextColor="Red" HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </HorizontalStackLayout>
        </VerticalStackLayout>

        <Grid Grid.Row="1" ColumnDefinitions="*, *" ColumnSpacing="15">

            <Grid Grid.Column="0" RowDefinitions="Auto, *">
                <Label Grid.Row="0" Text="BİLDİKLERİN" TextColor="LimeGreen" FontAttributes="Bold" HorizontalOptions="Center" Margin="0,0,0,5"/>
                <Border Grid.Row="1" BackgroundColor="#1A1A1A" Stroke="#333" StrokeThickness="1" StrokeShape="RoundRectangle 10" Padding="5">
                    <CollectionView x:Name="cvBilinenler">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Label Text="{Binding .}" TextColor="White" FontSize="14" Margin="0,2"/>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Border>
            </Grid>

            <Grid Grid.Column="1" RowDefinitions="Auto, *">
                <Label Grid.Row="0" Text="KAÇIRDIKLARIN" TextColor="Red" FontAttributes="Bold" HorizontalOptions="Center" Margin="0,0,0,5"/>
                <Border Grid.Row="1" BackgroundColor="#1A1A1A" Stroke="#333" StrokeThickness="1" StrokeShape="RoundRectangle 10" Padding="5">
                    <CollectionView x:Name="cvBilemediklerim">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Label Text="{Binding .}" TextColor="Gray" FontSize="14" Margin="0,2"/>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Border>
            </Grid>

        </Grid>

        <Grid Grid.Row="2" ColumnDefinitions="*, *" ColumnSpacing="10">
            <Button Grid.Column="0" Text="TEKRAR OYNA" Clicked="OnTekrarOynaClicked"
                    BackgroundColor="#1E88E5" TextColor="White" FontSize="14" FontAttributes="Bold" CornerRadius="10" HeightRequest="50"/>

            <Button Grid.Column="1" Text="ANA MENÜ" Clicked="OnAnaMenuClicked"
                    BackgroundColor="#333333" TextColor="White" FontSize="14" FontAttributes="Bold" CornerRadius="10" HeightRequest="50"/>
        </Grid>

    </Grid>
</ContentPage>