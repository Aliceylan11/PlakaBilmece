<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PlakaBilmece.MainPage"
             BackgroundColor="#121212"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="4*, 6*, 2*" Padding="20">

        <VerticalStackLayout Grid.Row="0" VerticalOptions="Center" Spacing="5">
            <Label Text="PLAKA" FontSize="42" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center"/>
            <Label Text="BİLMECE" FontSize="36" FontAttributes="Bold" TextColor="Gold" HorizontalOptions="Center"/>
            <Label Text="Zamana Karşı Yarış!" FontSize="14" TextColor="LightGray" HorizontalOptions="Center" Margin="0,10,0,0"/>
        </VerticalStackLayout>

        <VerticalStackLayout Grid.Row="1" VerticalOptions="Center" Spacing="20">

            <Button x:Name="btnIlTahmin" Text="İLLERİ TAHMİN ET" Clicked="OnIlTahminClicked"
                    BackgroundColor="#1E88E5" TextColor="White" FontSize="18" FontAttributes="Bold" 
                    HeightRequest="70" CornerRadius="15"/>

            <Button x:Name="btnIlceTahmin" Text="İLÇELERİ TAHMİN ET" Clicked="OnIlceTahminClicked"
                    BackgroundColor="#E53935" TextColor="White" FontSize="18" FontAttributes="Bold" 
                    HeightRequest="70" CornerRadius="15"/>

        </VerticalStackLayout>

        <Label Grid.Row="2" Text="v1.0 - Süre 2 Dakika" FontSize="12" TextColor="Gray" 
               HorizontalOptions="Center" VerticalOptions="End" Margin="0,0,0,10"/>

    </Grid>

</ContentPage>